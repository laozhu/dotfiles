#!/usr/bin/env bash
#
# yadm bootstrap — provisions a fresh macOS to match this dotfiles repo.
# Runs automatically after `yadm clone`, or manually via `yadm bootstrap`.
#
# Idempotent: every step guards against re-running. Safe to invoke repeatedly.

set -euo pipefail

cd "$HOME"

# ── CLI flags ────────────────────────────────────────────────────────────────
# NOTE: `yadm bootstrap` does NOT forward extra argv to this script — calling
# `yadm bootstrap --dry-run` will silently ignore the flag and execute for real.
# To pass options through yadm, use the env vars below; or invoke this script
# directly: `~/.config/yadm/bootstrap --dry-run`.
DRY_RUN="${BOOTSTRAP_DRY_RUN:-0}"
for arg in "$@"; do
    case "$arg" in
        --dry-run|-n) DRY_RUN=1 ;;
        --yes|-y)     BOOTSTRAP_YES=1 ;;
        --help|-h)
            cat <<EOF
Usage: ~/.config/yadm/bootstrap [--dry-run|-n] [--yes|-y] [--help|-h]

  --dry-run, -n   Print what would happen without executing.
  --yes, -y       Auto-approve dangerous steps (chsh, sudo).
                  Equivalent to BOOTSTRAP_YES=1.
  --help, -h      Show this message.

Environment (use these when invoking via \`yadm bootstrap\`, which doesn't
forward argv):
  BOOTSTRAP_DRY_RUN=1   Same as --dry-run.
  BOOTSTRAP_YES=1       Same as --yes.
EOF
            exit 0
            ;;
    esac
done

# ── Output helpers ────────────────────────────────────────────────────────────
log()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!! \033[0m %s\n' "$*" >&2; }
err()  { printf '\033[1;31mxx \033[0m %s\n' "$*" >&2; exit 1; }
dry()  { printf '\033[1;35m[dry-run]\033[0m %s\n' "$*"; }

# Run a command, or print it under --dry-run.
run() {
    if [[ "$DRY_RUN" == "1" ]]; then
        dry "$*"
    else
        "$@"
    fi
}

# ── Confirmation prompt for dangerous steps (chsh, sudo writes, etc.) ────────
# Default NO (safe); set BOOTSTRAP_YES=1 to auto-approve for unattended runs.
# Under --dry-run, prompts are shown but auto-approved so the trace continues.
confirm() {
    local msg="${1:-Continue?}"
    if [[ "$DRY_RUN" == "1" ]]; then
        dry "would prompt: $msg"
        return 0
    fi
    if [[ "${BOOTSTRAP_YES:-}" == "1" ]]; then
        log "Auto-approved (BOOTSTRAP_YES=1): $msg"
        return 0
    fi
    printf '\033[1;33m?? \033[0m %s [y/N] ' "$msg"
    read -r reply </dev/tty
    [[ "$reply" =~ ^[Yy]$ ]]
}

[[ "$DRY_RUN" == "1" ]] && log "DRY-RUN mode: no system changes will be made."

# ── Detect architecture ──────────────────────────────────────────────────────
if [[ "$(uname -m)" == "arm64" ]]; then
    BREW_PREFIX="/opt/homebrew"
else
    BREW_PREFIX="/usr/local"
fi

# ── 1. Xcode Command Line Tools ──────────────────────────────────────────────
if ! xcode-select -p >/dev/null 2>&1; then
    log "Installing Xcode Command Line Tools (GUI prompt will open)..."
    run xcode-select --install || true
    if [[ "$DRY_RUN" != "1" ]]; then
        log "Press <enter> once the CLT installer reports success..."
        read -r </dev/tty
    fi
fi

# ── 2. Homebrew ──────────────────────────────────────────────────────────────
if [[ ! -x "$BREW_PREFIX/bin/brew" ]]; then
    log "Installing Homebrew..."
    run sh -c 'NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'
fi
# Guard the shellenv eval — on a fresh machine in --dry-run, brew won't exist yet.
if [[ -x "$BREW_PREFIX/bin/brew" ]]; then
    eval "$("$BREW_PREFIX/bin/brew" shellenv)"
fi

# ── 3. Install everything from the Brewfile ──────────────────────────────────
if [[ -f "$HOME/.Brewfile" ]]; then
    log "Installing formulas, casks, and VS Code extensions from ~/.Brewfile..."
    # Newer brew-bundle no longer writes a lock file by default, and the
    # old `--no-lock` flag was removed — don't pass it.
    run brew bundle --global || warn "Some packages failed; continuing."
else
    warn "~/.Brewfile not found — skipping brew bundle."
fi

# ── 4. Oh My Zsh ─────────────────────────────────────────────────────────────
# RUNZSH=no    : don't drop into zsh after install
# CHSH=no      : don't change default shell (we handle that ourselves below)
# KEEP_ZSHRC=y : critical — preserves the tracked .zshrc instead of overwriting
if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
    log "Installing Oh My Zsh..."
    run sh -c 'RUNZSH=no CHSH=no KEEP_ZSHRC=yes sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"'
fi

# ── 5. fzf shell integration ─────────────────────────────────────────────────
# Installs key bindings and completions. --no-update-rc avoids touching .zshrc.
if [[ -x "$BREW_PREFIX/opt/fzf/install" ]]; then
    log "Wiring up fzf key bindings & completions..."
    run "$BREW_PREFIX/opt/fzf/install" \
        --key-bindings --completion --no-update-rc --no-bash --no-fish
fi

# ── 6. tealdeer cache ────────────────────────────────────────────────────────
if command -v tldr >/dev/null 2>&1; then
    log "Updating tealdeer (tldr) cache..."
    run tldr --update || warn "tldr cache update failed; non-fatal."
fi

# ── 7. Playwright browsers & Claude skill ────────────────────────────────────
# `playwright-cli install` downloads the browser binaries into
# ~/Library/Caches/ms-playwright/ (skipped if already present).
# `--skills` installs the Claude skill into ~/.claude/skills.
if command -v playwright-cli >/dev/null 2>&1; then
    log "Installing Playwright browser binaries..."
    run playwright-cli install || warn "playwright-cli install failed; non-fatal."
    log "Installing Playwright Claude skill..."
    run playwright-cli install --skills || warn "playwright-cli install --skills failed; non-fatal."
fi

# ── 8. Claude Code plugins & skills ──────────────────────────────────────────
# Plugin marketplaces and plugins aren't restored by yadm clone — only the
# manifest (~/.claude/plugins/installed_plugins.json) is tracked. Re-add the
# marketplaces and install each plugin; both commands are idempotent.
if command -v claude >/dev/null 2>&1; then
    log "Re-adding Claude plugin marketplaces..."
    for repo in \
        anthropics/claude-plugins-official \
        openai/codex-plugin-cc \
        Lum1104/Understand-Anything; do
        run claude plugin marketplace add "$repo" \
            || warn "marketplace add $repo failed; non-fatal."
    done

    log "Installing Claude plugins..."
    while IFS= read -r plugin; do
        [[ -z "$plugin" || "$plugin" == \#* ]] && continue
        run claude plugin install "$plugin" \
            || warn "plugin install $plugin failed; non-fatal."
    done <<'PLUGINS'
chrome-devtools-mcp@claude-plugins-official
claude-code-setup@claude-plugins-official
claude-md-management@claude-plugins-official
code-modernization@claude-plugins-official
commit-commands@claude-plugins-official
context7@claude-plugins-official
discord@claude-plugins-official
expo@claude-plugins-official
frontend-design@claude-plugins-official
greptile@claude-plugins-official
hyperframes@claude-plugins-official
learning-output-style@claude-plugins-official
mcp-server-dev@claude-plugins-official
playground@claude-plugins-official
pr-review-toolkit@claude-plugins-official
resend@claude-plugins-official
security-guidance@claude-plugins-official
skill-creator@claude-plugins-official
superpowers@claude-plugins-official
typescript-lsp@claude-plugins-official
codex@openai-codex
understand-anything@understand-anything
PLUGINS
fi

# `npx skills add` pulls standalone Claude skills into ~/.agents/skills/,
# which Claude Code reads alongside ~/.claude/skills/. larksuite/cli covers
# the lark-* suite; mattpocock/skills covers tdd/diagnose/prototype/etc.
if command -v npx >/dev/null 2>&1; then
    log "Installing standalone Claude skills (lark + mattpocock)..."
    run npx -y skills add larksuite/cli -g -y \
        || warn "lark skills install failed; non-fatal."
    run npx -y skills add mattpocock/skills -g -y \
        || warn "mattpocock skills install failed; non-fatal."
fi

# ── 9. ⚠️  DANGER ZONE: change default login shell ───────────────────────────
# Switches your login shell to the Homebrew zsh (newer than /bin/zsh).
# This modifies /etc/shells (sudo) and dscl user record — hence the prompt.
ZSH_PATH="$BREW_PREFIX/bin/zsh"
CURRENT_SHELL=$(dscl . -read "/Users/$USER" UserShell 2>/dev/null | awk '{print $2}')
if [[ -x "$ZSH_PATH" || "$DRY_RUN" == "1" ]] && [[ "$CURRENT_SHELL" != "$ZSH_PATH" ]]; then
    if confirm "Set default login shell to $ZSH_PATH (currently $CURRENT_SHELL)?"; then
        if ! grep -qx "$ZSH_PATH" /etc/shells 2>/dev/null; then
            log "Adding $ZSH_PATH to /etc/shells (sudo required)..."
            run sh -c "echo '$ZSH_PATH' | sudo tee -a /etc/shells >/dev/null"
        fi
        run chsh -s "$ZSH_PATH" && log "Default shell updated. Open a new terminal."
    else
        warn "Skipped shell change. Current shell remains: $CURRENT_SHELL"
    fi
fi

# ── 10. GitHub token in macOS Keychain ───────────────────────────────────────
# .zshrc reads GITHUB_PERSONAL_ACCESS_TOKEN from the Keychain via:
#   security find-generic-password -s "github-token" -w
# Prompt for the token (or pick up GITHUB_TOKEN env var) and save it.
if ! security find-generic-password -s "github-token" >/dev/null 2>&1; then
    log "No Keychain entry 'github-token' found — needed by ~/.zshrc."
    if [[ "$DRY_RUN" == "1" ]]; then
        dry "would prompt for GitHub PAT and save via security add-generic-password"
    else
        token="${GITHUB_TOKEN:-}"
        if [[ -z "$token" ]]; then
            printf '\033[1;33m?? \033[0m Enter GitHub Personal Access Token (hidden, blank to skip): '
            read -rs token </dev/tty
            echo
        fi
        if [[ -n "$token" ]]; then
            security add-generic-password -s "github-token" -a "$USER" -w "$token"
            log "Saved 'github-token' to Keychain."
        else
            warn "Skipped — add manually later with:"
            warn "  security add-generic-password -s 'github-token' -a \"\$USER\" -w <YOUR_TOKEN>"
        fi
        unset token
    fi
fi

log "Bootstrap complete. Open a new terminal to load the full environment."
