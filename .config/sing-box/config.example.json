{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    },
    "clash_api": {
      "default_mode": "Enhanced",
      "external_controller": "127.0.0.1:9090",
      "external_ui": "dashboard",
      "external_ui_download_detour": "aws-singapore"
    }
  },
  "inbounds": [
    {
      "tag": "tun-in",
      "type": "tun",
      "address": ["172.19.0.1/30"],
      "auto_route": true,
      "strict_route": true
    },
    {
      "tag": "mixed-in",
      "type": "mixed",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "type": "direct"
    },
    {
      "tag": "aws-singapore",
      "type": "vless",
      "server": "YOUR_SERVER_DOMAIN",
      "server_port": 443,
      "flow": "xtls-rprx-vision",
      "network": "tcp",
      "domain_resolver": "local-dns",
      "uuid": "YOUR_UUID",
      "tls": {
        "enabled": true,
        "server_name": "www.microsoft.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "YOUR_PUBLIC_KEY",
          "short_id": "YOUR_SHORT_ID"
        }
      }
    }
  ],
  "dns": {
    "servers": [
      {
        "tag": "local-dns",
        "type": "https",
        "server": "223.5.5.5",
        "server_port": 443
      },
      {
        "tag": "proxy-dns",
        "type": "https",
        "server": "1.1.1.1",
        "server_port": 443,
        "path": "/dns-query",
        "detour": "aws-singapore"
      }
    ],
    "rules": [
      {
        "domain": ["YOUR_SERVER_DOMAIN"],
        "server": "local-dns"
      },
      {
        "rule_set": ["claude.ai", "openai.com", "paid.inc", "site-!cn"],
        "action": "route",
        "server": "proxy-dns"
      }
    ],
    "final": "local-dns",
    "strategy": "prefer_ipv4"
  },
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "local-dns",
    "rule_set": [
      {
        "tag": "claude.ai",
        "type": "inline",
        "rules": [
          {
            "domain_suffix": [
              "anthropic.com",
              "claude.ai",
              "claude.com",
              "claudeusercontent.com",
              "claude.site",
              "claudemcpcontent.com",
              "claudemcpclient.com"
            ]
          }
        ]
      },
      {
        "tag": "openai.com",
        "type": "inline",
        "rules": [
          {
            "domain_suffix": ["openai.com", "chatgpt.com", "oaistatic.com", "oaiusercontent.com"]
          }
        ]
      },
      {
        "tag": "paid.inc",
        "type": "inline",
        "rules": [
          {
            "domain_suffix": ["paid.inc"]
          }
        ]
      },
      {
        "tag": "site-!cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-!cn.srs",
        "download_detour": "aws-singapore"
      }
    ],
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "rule_set": ["claude.ai", "openai.com", "paid.inc", "site-!cn"],
        "outbound": "aws-singapore"
      }
    ],
    "final": "direct"
  }
}
